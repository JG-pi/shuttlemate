rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Auth tokens must verify the email address
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.email == 'jamesguoas@gmail.com' ||
        request.auth.token.email == 'khoiphan21@gmail.com' ||
        request.auth.token.email == 'admin@luna.academy'
      );
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper representations of incoming and existing data
    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation definitions
    function isValidEvent(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 128 &&
             data.date is string && data.date.size() > 0 &&
             data.capacity is int && data.capacity >= 1 &&
             data.location is string && data.location.size() <= 256 &&
             data.additionalInfo is string && data.additionalInfo.size() <= 10000 &&
             (data.cost is int || data.cost is float) && data.cost >= 0 &&
             (!data.keys().hasAny(['durationHours']) || ((data.durationHours is int || data.durationHours is float) && data.durationHours > 0)) &&
             (!data.keys().hasAny(['courtCost']) || ((data.courtCost is int || data.courtCost is float) && data.courtCost >= 0)) &&
             (!data.keys().hasAny(['shuttlecockCost']) || ((data.shuttlecockCost is int || data.shuttlecockCost is float) && data.shuttlecockCost >= 0)) &&
             data.finalised is bool &&
             data.createdBy is string &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidBooking(data) {
      return data.eventId is string && data.eventId.size() > 0 && data.eventId.size() <= 128 &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() <= 128 &&
             data.userEmail is string && data.userEmail.size() > 0 && data.userEmail.size() <= 256 &&
             data.userName is string && data.userName.size() > 0 && data.userName.size() <= 128 &&
             data.paid is bool &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isNullableString(value, maxLength) {
      return value == null || (value is string && value.size() <= maxLength);
    }

    function isValidUserProfile(data) {
      return data.keys().hasOnly([
               'uid',
               'email',
               'displayName',
               'photoURL',
               'providerId',
               'emailVerified',
               'createdAt',
               'updatedAt',
               'lastLoginAt'
             ]) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.email == request.auth.token.email &&
             data.displayName is string &&
             data.displayName.size() > 0 &&
             data.displayName.size() <= 128 &&
             isNullableString(data.photoURL, 2048) &&
             data.providerId is string &&
             data.providerId.size() > 0 &&
             data.providerId.size() <= 64 &&
             data.emailVerified is bool &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             data.lastLoginAt is timestamp;
    }

    function isValidLocation(data) {
      return data.keys().hasOnly([
               'id',
               'name',
               'pricePerCourtHour',
               'createdAt',
               'updatedAt',
               'createdBy'
             ]) &&
             data.id is string &&
             isValidId(data.id) &&
             data.name is string &&
             data.name.size() > 0 &&
             data.name.size() <= 128 &&
             (data.pricePerCourtHour is int || data.pricePerCourtHour is float) &&
             data.pricePerCourtHour >= 0 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             data.createdBy is string;
    }

    function isValidShuttlecock(data) {
      return data.keys().hasOnly([
               'id',
               'name',
               'pricePerTube',
               'createdAt',
               'updatedAt',
               'createdBy'
             ]) &&
             data.id is string &&
             isValidId(data.id) &&
             data.name is string &&
             data.name.size() > 0 &&
             data.name.size() <= 128 &&
             (data.pricePerTube is int || data.pricePerTube is float) &&
             data.pricePerTube >= 0 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             data.createdBy is string;
    }

    function isNullableText(value, maxLength) {
      return value == null || (value is string && value.size() <= maxLength);
    }

    function isValidRuntimeError(data) {
      return data.keys().hasOnly([
               'id',
               'area',
               'stage',
               'message',
               'code',
               'name',
               'stack',
               'attemptedEmail',
               'userId',
               'userEmail',
               'emailVerified',
               'providerIds',
               'route',
               'url',
               'userAgent',
               'online',
               'projectId',
               'authDomain',
               'databaseId',
               'contextJson',
               'createdAt'
             ]) &&
             data.id is string &&
             isValidId(data.id) &&
             data.area is string &&
             data.area.size() > 0 &&
             data.area.size() <= 64 &&
             data.stage is string &&
             data.stage.size() > 0 &&
             data.stage.size() <= 128 &&
             data.message is string &&
             data.message.size() > 0 &&
             data.message.size() <= 2000 &&
             isNullableText(data.code, 128) &&
             isNullableText(data.name, 128) &&
             isNullableText(data.stack, 6000) &&
             isNullableText(data.attemptedEmail, 256) &&
             isNullableText(data.userId, 128) &&
             isNullableText(data.userEmail, 256) &&
             (data.emailVerified == null || data.emailVerified is bool) &&
             data.providerIds is string &&
             data.providerIds.size() <= 256 &&
             isNullableText(data.route, 512) &&
             isNullableText(data.url, 2048) &&
             isNullableText(data.userAgent, 1024) &&
             (data.online == null || data.online is bool) &&
             data.projectId is string &&
             data.projectId.size() <= 128 &&
             data.authDomain is string &&
             data.authDomain.size() <= 256 &&
             data.databaseId is string &&
             data.databaseId.size() <= 128 &&
             data.contextJson is string &&
             data.contextJson.size() <= 8000 &&
             data.createdAt is timestamp;
    }

    // MATCH MODULE: USERS
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      allow create: if isSignedIn() &&
                    request.auth.uid == userId &&
                    isValidUserProfile(incoming()) &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time &&
                    incoming().lastLoginAt == request.time;

      allow update: if isSignedIn() &&
                    request.auth.uid == userId &&
                    isValidUserProfile(incoming()) &&
                    incoming().uid == existing().uid &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time &&
                    incoming().lastLoginAt == request.time;
    }

    // MATCH MODULE: RUNTIME ERROR LOGS
    match /RuntimeError/{errorId} {
      allow create: if isValidId(errorId) &&
                    isValidRuntimeError(incoming()) &&
                    incoming().id == errorId &&
                    incoming().createdAt == request.time;

      allow read, get, list, delete: if isAdmin();
      allow update: if false;
    }

    // MATCH MODULE: ADMIN LOCATION SETTINGS
    match /locations/{locationId} {
      allow read, get, list: if isAdmin();

      allow create: if isAdmin() &&
                    isValidId(locationId) &&
                    isValidLocation(incoming()) &&
                    incoming().id == locationId &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time &&
                    incoming().createdBy == request.auth.uid;

      allow update: if isAdmin() &&
                    isValidId(locationId) &&
                    isValidLocation(incoming()) &&
                    incoming().id == existing().id &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().createdBy == existing().createdBy &&
                    incoming().updatedAt == request.time;

      allow delete: if isAdmin() && isValidId(locationId);
    }

    // MATCH MODULE: ADMIN SHUTTLECOCK SETTINGS
    match /shuttlecocks/{shuttlecockId} {
      allow read, get, list: if isAdmin();

      allow create: if isAdmin() &&
                    isValidId(shuttlecockId) &&
                    isValidShuttlecock(incoming()) &&
                    incoming().id == shuttlecockId &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time &&
                    incoming().createdBy == request.auth.uid;

      allow update: if isAdmin() &&
                    isValidId(shuttlecockId) &&
                    isValidShuttlecock(incoming()) &&
                    incoming().id == existing().id &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().createdBy == existing().createdBy &&
                    incoming().updatedAt == request.time;

      allow delete: if isAdmin() && isValidId(shuttlecockId);
    }

    // MATCH MODULE: EVENTS
    match /events/{eventId} {
      allow read, get, list: if isSignedIn();

      allow create: if isAdmin() && isValidId(eventId) && isValidEvent(incoming()) &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time &&
                    incoming().createdBy == request.auth.uid &&
                    incoming().finalised == false;

      allow update: if isAdmin() && isValidId(eventId) && isValidEvent(incoming()) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().createdBy == existing().createdBy &&
                    incoming().updatedAt == request.time &&
                    (
                      // Locked event modification check: 
                      // If it is already finalised, admins can still modify fields (override),
                      // but we explicitly log that they can change finalized status or details.
                      incoming().finalised != existing().finalised ||
                      incoming().diff(existing()).affectedKeys().hasAny(['name', 'date', 'durationHours', 'capacity', 'location', 'additionalInfo', 'cost', 'courtCost', 'shuttlecockCost', 'finalised', 'updatedAt'])
                    );

      allow delete: if isAdmin() && isValidId(eventId);
    }

    // MATCH MODULE: BOOKINGS
    match /bookings/{bookingId} {
      // The event catalog reads bookings to calculate participant counts and split costs.
      allow read, get, list: if isSignedIn();

      allow create: if isSignedIn() && isValidId(bookingId) && isValidBooking(incoming()) &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time &&
                    (
                      // Case A: Admin can book for any user
                      isAdmin() ||
                      // Case B: Regular user books for themselves
                      (
                        incoming().userId == request.auth.uid &&
                        incoming().userEmail == request.auth.token.email &&
                        incoming().paid == false &&
                        // Master Gate check: Check if the referenced event exists and is not finalised
                        exists(/databases/$(database)/documents/events/$(incoming().eventId)) &&
                        get(/databases/$(database)/documents/events/$(incoming().eventId)).data.finalised == false
                      )
                    );

      allow update: if isEmailVerified() && isValidId(bookingId) && isValidBooking(incoming()) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().eventId == existing().eventId &&
                    incoming().userId == existing().userId &&
                    incoming().userEmail == existing().userEmail &&
                    incoming().userName == existing().userName &&
                    incoming().updatedAt == request.time &&
                    (
                      // Only admin can change paid status
                      isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['paid', 'updatedAt'])
                    );

      allow delete: if isSignedIn() && isValidId(bookingId) && (
                    // Case A: Admin can delete any booking
                    isAdmin() ||
                    // Case B: Regular owner can cancel signup ONLY if the event is not finalized
                    (
                      existing().userId == request.auth.uid &&
                      exists(/databases/$(database)/documents/events/$(existing().eventId)) &&
                      get(/databases/$(database)/documents/events/$(existing().eventId)).data.finalised == false
                    )
                  );
    }
  }
}
