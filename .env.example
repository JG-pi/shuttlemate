# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase config used by dev builds when running npm run build:dev
# or npm run start:dev. Keep real environment values in .env.development or
# deployment secrets, not in git.
DEV_FIREBASE_API_KEY="MY_DEV_FIREBASE_API_KEY"
DEV_FIREBASE_AUTH_DOMAIN="MY_DEV_FIREBASE_AUTH_DOMAIN"
DEV_FIREBASE_PROJECT_ID="MY_DEV_FIREBASE_PROJECT_ID"
DEV_FIREBASE_STORAGE_BUCKET="MY_DEV_FIREBASE_STORAGE_BUCKET"
DEV_FIREBASE_MESSAGING_SENDER_ID="MY_DEV_FIREBASE_MESSAGING_SENDER_ID"
DEV_FIREBASE_APP_ID="MY_DEV_FIREBASE_APP_ID"
DEV_FIREBASE_MEASUREMENT_ID="MY_DEV_FIREBASE_MEASUREMENT_ID"
DEV_FIREBASE_FIRESTORE_DATABASE_ID="(default)"

# Firebase config used by staging builds. Keep real environment values in
# .env.staging or deployment secrets, not in git.
STAGING_FIREBASE_API_KEY="MY_STAGING_FIREBASE_API_KEY"
STAGING_FIREBASE_AUTH_DOMAIN="MY_STAGING_FIREBASE_AUTH_DOMAIN"
STAGING_FIREBASE_PROJECT_ID="MY_STAGING_FIREBASE_PROJECT_ID"
STAGING_FIREBASE_STORAGE_BUCKET="MY_STAGING_FIREBASE_STORAGE_BUCKET"
STAGING_FIREBASE_MESSAGING_SENDER_ID="MY_STAGING_FIREBASE_MESSAGING_SENDER_ID"
STAGING_FIREBASE_APP_ID="MY_STAGING_FIREBASE_APP_ID"
STAGING_FIREBASE_MEASUREMENT_ID="MY_STAGING_FIREBASE_MEASUREMENT_ID"
STAGING_FIREBASE_FIRESTORE_DATABASE_ID="(default)"
